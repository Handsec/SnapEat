.page {
  padding-bottom: 160rpx;
}

/* 分类标签 */
.cat-bar {
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: #faf9f7;
  position: sticky;
  top: 0;
  z-index: 10;
}

.cat-pill {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.cat-pill.active {
  background: linear-gradient(135deg, #f05a28, #ff8a4a);
  color: #fff;
  transform: scale(1.05);
}

.cat-count {
  font-size: 22rpx;
  opacity: 0.7;
  margin-left: 6rpx;
}

/* 菜品卡片 */
.items {
  padding: 8rpx 24rpx;
}

.dish-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.dish-head {
  display: flex;
}

.dish-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fff0e8, #ffe0d0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-names {
  display: flex;
  align-items: center;
}

.dish-name-tr {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.spice {
  font-size: 24rpx;
  margin-left: 12rpx;
}

.dish-name-orig {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.dish-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #f05a28;
}

.price-orig {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.conf {
  font-size: 20rpx;
  color: #aaa;
  margin-left: auto;
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

/* 详情 */
.dish-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-row {
  display: flex;
  margin-bottom: 14rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  width: 88rpx;
  flex-shrink: 0;
}

.detail-text {
  font-size: 26rpx;
  color: #555;
  flex: 1;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  flex: 1;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin: 0 12rpx 8rpx 0;
}

.tag.warn {
  background: #fff3e0;
  color: #e67700;
}

.tag.risk {
  background: #ffebee;
  color: #c62828;
}

/* 加减栏 */
.qty-bar {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.taste-tags {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
}

.ttag {
  font-size: 22rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin: 0 10rpx 6rpx 0;
}

.qty-ctrl {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
}

.qty-btn.plus {
  background: linear-gradient(135deg, #f05a28, #ff8a4a);
  color: #fff;
}

.qty-btn.minus {
  background: #f0f0f0;
  color: #666;
}

.qty-num {
  font-size: 32rpx;
  font-weight: 600;
  min-width: 56rpx;
  text-align: center;
}

/* 底部悬浮栏 */
.footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  height: 100rpx;
  background: #1a1a1a;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
}

.footer-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #f05a28;
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.footer-text {
  display: flex;
  flex-direction: column;
}

.footer-total {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.footer-hint {
  color: #999;
  font-size: 22rpx;
}

.footer-btn {
  background: linear-gradient(135deg, #f05a28, #ff8a4a);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 48rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
}
