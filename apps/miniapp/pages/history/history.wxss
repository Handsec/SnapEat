.page {
  padding: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hist-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.hist-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fff0e8, #ffe0d0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.hist-info {
  flex: 1;
  min-width: 0;
}

.hist-top {
  display: flex;
  align-items: center;
}

.hist-lang {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-transform: uppercase;
}

.hist-count {
  font-size: 24rpx;
  color: #f05a28;
  background: #fff0e8;
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.hist-time {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.hist-del {
  font-size: 26rpx;
  color: #c62828;
  padding: 12rpx 24rpx;
  flex-shrink: 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
